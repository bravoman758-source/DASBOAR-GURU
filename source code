import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  onAuthStateChanged, 
  signInWithEmailAndPassword,
  createUserWithEmailAndPassword,
  signInWithCustomToken,
  signInAnonymously,
  signOut
} from 'firebase/auth';
import { 
  getFirestore, 
  doc, 
  onSnapshot, 
  collection, 
  setDoc,
  getDoc
} from 'firebase/firestore';
import { 
  LayoutDashboard, 
  Package, 
  Users, 
  CreditCard, 
  List, 
  Settings, 
  Bell, 
  MoreVertical,
  ChevronDown,
  TrendingUp,
  DollarSign,
  ShoppingCart,
  Clock,
  Lock,
  ArrowDownRight,
  Bot,
  Save,
  LogIn,
  Eye,
  EyeOff,
  LogOut,
  User,
  FileText,
  ArrowRightLeft,
  Download,
  UserPlus,
  AlertTriangle,
  CheckCircle2,
  ShieldAlert,
  Filter
} from 'lucide-react';

// --- Konfigurasi Firebase ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'mn-store-app';

// Pemetaan Ikon untuk statistik
const ICON_MAP = { 
  CreditCard, Clock, Lock, ArrowDownRight, Package, TrendingUp, DollarSign, ShoppingCart, Bot 
};

// Komponen Logo MN (Nuansa Kuning-Hitam)
const MNLogo = ({ className = "w-10 h-10" }) => (
  <div className={`${className} bg-amber-400 rounded-full flex items-center justify-center relative overflow-hidden shadow-xl ring-4 ring-black/5`}>
    <div className="text-black font-black italic text-xl tracking-tighter leading-none select-none">
      MN
    </div>
  </div>
);

export default function App() {
  const [user, setUser] = useState(null);
  const [authLoading, setAuthLoading] = useState(true);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [isSidebarOpen, setIsSidebarOpen] = useState(true);
  const [currentTime, setCurrentTime] = useState(new Date());
  
  // State Autentikasi
  const [authMode, setAuthMode] = useState('login'); 
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [showPassword, setShowPassword] = useState(false);
  const [authMessage, setAuthMessage] = useState({ type: '', text: '' });
  const [isSubmitting, setIsSubmitting] = useState(false);

  // State Data Real-time
  const [stats, setStats] = useState([]);
  const [botConfig, setBotConfig] = useState({ token: '', botUsername: '', status: 'Offline' });

  // 1. Inisialisasi Autentikasi
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) {
        console.error("Kesalahan Auth Awal:", error);
      }
    };

    initAuth();

    const unsubscribe = onAuthStateChanged(auth, (currentUser) => {
      setUser(currentUser);
      setAuthLoading(false);
    });
    return () => unsubscribe();
  }, []);

  // 2. Sinkronisasi Data Firestore
  useEffect(() => {
    if (!user) return;

    // Listener Statistik
    const statsRef = collection(db, 'artifacts', appId, 'public', 'data', 'stats');
    const unsubStats = onSnapshot(statsRef, (snapshot) => {
      const statsData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      if (statsData.length > 0) setStats(statsData);
      else initializeDefaultData();
    }, (err) => console.error("Firestore Stats Error:", err));

    // Listener Konfigurasi Bot
    const configRef = doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'bot_config');
    const unsubConfig = onSnapshot(configRef, (docSnap) => {
      if (docSnap.exists()) setBotConfig(docSnap.data());
    }, (err) => console.error("Firestore Config Error:", err));

    return () => {
      unsubStats();
      unsubConfig();
    };
  }, [user]);

  const initializeDefaultData = async () => {
    if (!user) return;
    const defaultStats = [
      { key: 'saldo_tersedia', label: 'Saldo Tersedia', value: 'Rp 213.200', color: 'text-green-600', bg: 'bg-green-50', icon: 'CreditCard' },
      { key: 'saldo_pending', label: 'Saldo Pending', value: 'Rp 413.300', color: 'text-amber-600', bg: 'bg-amber-50', icon: 'Clock' },
      { key: 'saldo_keluar', label: 'Saldo Keluar', value: 'Rp 78.677.000', color: 'text-slate-600', bg: 'bg-slate-50', icon: 'ArrowDownRight' },
      { key: 'jumlah_produk', label: 'Jumlah Produk', value: '124', color: 'text-indigo-600', bg: 'bg-indigo-50', icon: 'Package' },
    ];
    try {
      for (const s of defaultStats) {
        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'stats', s.key), s);
      }
      const configRef = doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'bot_config');
      await setDoc(configRef, { token: '', botUsername: '', status: 'Offline' }, { merge: true });
    } catch (e) { console.error("Gagal Inisialisasi Data:", e); }
  };

  useEffect(() => {
    const timer = setInterval(() => setCurrentTime(new Date()), 1000);
    return () => clearInterval(timer);
  }, []);

  const handleAuth = async (e) => {
    e.preventDefault();
    setAuthMessage({ type: '', text: '' });
    setIsSubmitting(true);
    
    try {
      if (authMode === 'login') {
        await signInWithEmailAndPassword(auth, email, password);
      } else {
        await createUserWithEmailAndPassword(auth, email, password);
        setAuthMode('login');
        setAuthMessage({ type: 'success', text: 'Registrasi Berhasil! Silakan Login.' });
      }
    } catch (error) {
      let msg = 'Terjadi kesalahan sistem.';
      switch (error.code) {
        case 'auth/operation-not-allowed':
          msg = 'FITUR LOGIN BELUM AKTIF! Aktifkan Email/Password di Firebase Console.';
          break;
        case 'auth/email-already-in-use':
          msg = 'Email sudah terdaftar. Silakan pilih menu LOGIN.';
          break;
        case 'auth/wrong-password':
        case 'auth/user-not-found':
          msg = 'Email atau password salah, Bro.';
          break;
        case 'auth/weak-password':
          msg = 'Password minimal harus 6 karakter.';
          break;
        default:
          msg = error.message;
      }
      setAuthMessage({ type: 'error', text: msg });
    } finally {
      setIsSubmitting(false);
    }
  };

  const handleLogout = () => signOut(auth);

  const renderIcon = (iconName, className) => {
    const IconComponent = ICON_MAP[iconName] || Package;
    return <IconComponent className={className} />;
  };

  // --- TAMPILAN SUB-MENU ---

  const renderDashboard = () => (
    <div className="space-y-8 animate-in fade-in duration-700">
      <div className="bg-slate-900 rounded-[50px] p-12 text-white shadow-2xl relative overflow-hidden border border-slate-800">
        <div className="relative z-10">
          <div className="flex items-center gap-6 mb-8">
            <MNLogo className="w-20 h-20 border-4 border-white/5 shadow-2xl" />
            <div>
              <h2 className="text-5xl font-black italic tracking-tighter leading-none">MN STORE</h2>
              <p className="text-amber-400 text-xs font-black uppercase tracking-[0.4em] opacity-80 mt-2">Elite Dashboard Access</p>
            </div>
          </div>
          <p className="opacity-70 italic text-2xl mb-10 max-w-2xl leading-relaxed">"Konsistensi adalah jembatan antara tujuan dan pencapaian." ⚡</p>
          <div className="flex flex-wrap gap-5">
            <div className="bg-white/5 backdrop-blur-xl px-6 py-4 rounded-3xl text-sm font-black border border-white/5 uppercase tracking-widest shadow-inner">{currentTime.toLocaleTimeString('id-ID')} WIB</div>
            <div className="bg-white/5 backdrop-blur-xl px-6 py-4 rounded-3xl text-sm font-black border border-white/5 flex items-center gap-4 uppercase tracking-widest shadow-inner">
              <div className={`w-3.5 h-3.5 rounded-full ${botConfig.status === 'Online' ? 'bg-green-400 animate-pulse shadow-[0_0_15px_rgba(74,222,128,0.6)]' : 'bg-red-400 shadow-[0_0_15px_rgba(248,113,113,0.4)]'}`}></div>
              Bot: {botConfig.status || 'Offline'}
            </div>
          </div>
        </div>
        <div className="absolute top-[-50px] right-[-50px] w-[500px] h-[500px] bg-amber-400/5 rounded-full blur-[150px]"></div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div key={stat.id} className="bg-white p-10 rounded-[40px] shadow-sm border border-slate-100 flex flex-col gap-6 transition-all hover:border-amber-300 hover:shadow-2xl hover:shadow-amber-100/50 group cursor-default">
            <div className={`w-16 h-16 rounded-3xl flex items-center justify-center ${stat.bg || 'bg-slate-50'} group-hover:scale-110 transition-transform duration-500`}>
              <div className={stat.color}>{renderIcon(stat.icon, "w-8 h-8")}</div>
            </div>
            <div>
              <p className="text-[11px] text-slate-400 font-black uppercase tracking-[0.3em] mb-2">{stat.label}</p>
              <p className={`text-3xl font-black italic tracking-tight ${stat.color}`}>{stat.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  );

  const renderRekap = () => (
    <div className="space-y-8 animate-in slide-in-from-bottom-4 duration-500">
      <div className="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h2 className="text-4xl font-black italic text-slate-900 tracking-tighter uppercase">REKAP PRODUK</h2>
          <p className="text-slate-400 font-bold uppercase tracking-widest text-[10px] mt-2">Inventory & Performance Report</p>
        </div>
        <button className="bg-slate-900 text-amber-400 px-8 py-4 rounded-3xl font-black italic uppercase text-xs shadow-xl active:scale-95 transition-all flex items-center gap-3">
          <Download className="w-5 h-5" /> Export Data
        </button>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div className="lg:col-span-2 bg-white rounded-[45px] border border-slate-100 overflow-hidden shadow-sm">
          <table className="w-full text-left">
            <thead className="bg-slate-900 text-white">
              <tr>
                <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">Kategori</th>
                <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">Terjual</th>
                <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">Profit</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-slate-100">
              <tr className="hover:bg-slate-50 transition-colors">
                <td className="px-8 py-7 font-black italic text-slate-800">PREMIUM APPS</td>
                <td className="px-8 py-7 font-bold text-slate-500">452 pcs</td>
                <td className="px-8 py-7 font-black text-green-600">Rp 4.520.000</td>
              </tr>
              <tr className="hover:bg-slate-50 transition-colors">
                <td className="px-8 py-7 font-black italic text-slate-800">GAME TOPUP</td>
                <td className="px-8 py-7 font-bold text-slate-500">210 pcs</td>
                <td className="px-8 py-7 font-black text-green-600">Rp 2.100.000</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div className="bg-slate-900 rounded-[45px] p-10 text-white shadow-xl flex flex-col justify-between relative overflow-hidden">
          <div className="space-y-2 relative z-10">
            <TrendingUp className="w-10 h-10 text-amber-400 mb-4" />
            <p className="text-xs font-black uppercase tracking-[0.3em] text-slate-500">Best Seller</p>
            <p className="text-3xl font-black italic text-amber-400">SPOTIFY PREMIUM</p>
          </div>
          <div className="absolute top-[-20px] right-[-20px] w-32 h-32 bg-amber-400/5 rounded-full blur-2xl"></div>
        </div>
      </div>
    </div>
  );

  const renderTransaksi = () => (
    <div className="space-y-8 animate-in slide-in-from-bottom-4 duration-500">
      <div className="flex items-center justify-between">
        <h2 className="text-4xl font-black italic text-slate-900 tracking-tighter uppercase">TRANSAKSI LIVE</h2>
        <div className="flex gap-3">
          <div className="bg-white border border-slate-200 rounded-2xl px-4 py-2 flex items-center gap-3">
            <Filter className="w-4 h-4 text-slate-400" />
            <span className="text-[10px] font-black uppercase text-slate-500">Filter Status</span>
          </div>
        </div>
      </div>

      <div className="bg-white rounded-[45px] border border-slate-100 overflow-hidden shadow-sm">
        <table className="w-full text-left">
          <thead className="bg-slate-900 text-white">
            <tr>
              <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">ID</th>
              <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">Produk</th>
              <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">Nominal</th>
              <th className="px-8 py-6 text-[10px] font-black uppercase tracking-[0.3em]">Status</th>
            </tr>
          </thead>
          <tbody className="divide-y divide-slate-100">
            {[1, 2, 3, 4, 5].map((i) => (
              <tr key={i} className="hover:bg-slate-50 transition-colors">
                <td className="px-8 py-7 font-mono text-xs text-slate-400">#MN-TX-{1000+i}</td>
                <td className="px-8 py-7 font-black italic text-slate-800">Netflix Ultra HD</td>
                <td className="px-8 py-7 font-black text-slate-900">Rp 35.000</td>
                <td className="px-8 py-7">
                  <span className="bg-green-100 text-green-700 text-[10px] px-4 py-2 rounded-2xl font-black uppercase tracking-widest">SUCCESS</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );

  const renderAuthPage = () => (
    <div className="min-h-screen bg-slate-900 flex items-center justify-center p-4 relative overflow-hidden font-sans">
      <div className="absolute top-0 right-0 w-96 h-96 bg-amber-400/10 rounded-full blur-[150px] -mr-48 -mt-48"></div>
      
      <div className="max-w-md w-full bg-white rounded-[45px] shadow-2xl overflow-hidden relative z-10 animate-in fade-in zoom-in-95">
        <div className="bg-slate-900 p-12 text-center text-white relative">
          <MNLogo className="w-20 h-20 mx-auto mb-6 shadow-2xl shadow-amber-400/10" />
          <h2 className="text-3xl font-black italic tracking-tighter uppercase leading-none">
            {authMode === 'login' ? 'MASTER LOGIN' : 'CREATE ACCOUNT'}
          </h2>
          <div className="h-1.5 w-12 bg-amber-400 mx-auto mt-4 rounded-full"></div>
        </div>

        <div className="p-10 lg:p-12">
          <form onSubmit={handleAuth} className="space-y-6">
            {authMessage.text && (
              <div className={`p-4 rounded-2xl text-[10px] font-black border text-center uppercase flex items-center justify-center gap-3 animate-in slide-in-from-top-2 ${authMessage.type === 'success' ? 'bg-green-50 text-green-600 border-green-100' : 'bg-red-50 text-red-600 border-red-100'}`}>
                {authMessage.type === 'success' ? <CheckCircle2 className="w-5 h-5" /> : <ShieldAlert className="w-5 h-5" />}
                <span className="leading-tight">{authMessage.text}</span>
              </div>
            )}
            
            <div className="space-y-1.5">
              <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-3">Email Access</label>
              <div className="relative">
                <User className="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
                <input 
                  type="email" required value={email} onChange={(e) => setEmail(e.target.value)}
                  placeholder="owner@mnstore.id"
                  className="w-full pl-14 pr-5 py-4.5 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-100 focus:border-amber-400 font-bold text-sm"
                />
              </div>
            </div>

            <div className="space-y-1.5">
              <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-3">Security Key</label>
              <div className="relative">
                <Lock className="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
                <input 
                  type={showPassword ? "text" : "password"} required value={password} onChange={(e) => setPassword(e.target.value)}
                  placeholder="••••••••"
                  className="w-full pl-14 pr-14 py-4.5 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-100 focus:border-amber-400 font-bold text-sm"
                />
                <button type="button" onClick={() => setShowPassword(!showPassword)} className="absolute right-5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-amber-500 transition-colors p-1">
                  {showPassword ? <EyeOff className="w-5 h-5" /> : <Eye className="w-5 h-5" />}
                </button>
              </div>
            </div>

            <button 
              type="submit" disabled={isSubmitting}
              className="w-full bg-slate-900 text-amber-400 font-black uppercase italic py-5 rounded-[28px] shadow-2xl flex items-center justify-center gap-3 active:scale-95 transition-all mt-4"
            >
              {isSubmitting ? <div className="w-6 h-6 border-4 border-amber-400/30 border-t-amber-400 rounded-full animate-spin"></div> : (
                <>{authMode === 'login' ? <LogIn className="w-6 h-6" /> : <UserPlus className="w-6 h-6" />} {authMode.toUpperCase()}</>
              )}
            </button>
          </form>

          <div className="mt-12 flex flex-col items-center gap-4">
            <div className="flex bg-slate-50 p-1.5 rounded-2xl w-full">
              <button 
                onClick={() => { setAuthMode('login'); setAuthMessage({type:'', text:''}); }}
                className={`flex-1 py-3 rounded-xl font-black text-[10px] tracking-widest transition-all ${authMode === 'login' ? 'bg-amber-400 text-black shadow-lg shadow-amber-200' : 'text-slate-400 hover:text-slate-600'}`}
              >
                LOGIN
              </button>
              <button 
                onClick={() => { setAuthMode('register'); setAuthMessage({type:'', text:''}); }}
                className={`flex-1 py-3 rounded-xl font-black text-[10px] tracking-widest transition-all ${authMode === 'register' ? 'bg-amber-400 text-black shadow-lg shadow-amber-200' : 'text-slate-400 hover:text-slate-600'}`}
              >
                DAFTAR
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );

  // Tampilan Loading
  if (authLoading) {
    return (
      <div className="min-h-screen bg-slate-900 flex flex-col items-center justify-center gap-8">
        <MNLogo className="w-24 h-24 border-8 border-white/5 shadow-2xl shadow-amber-400/10" />
        <div className="space-y-4 text-center">
          <div className="w-48 h-1.5 bg-slate-800 rounded-full overflow-hidden">
            <div className="bg-amber-400 h-full w-1/2 animate-[loading_1.5s_infinite_ease-in-out]"></div>
          </div>
          <p className="text-amber-400 font-black italic uppercase text-xs tracking-[0.5em] animate-pulse">INITIATING MN OS...</p>
        </div>
      </div>
    );
  }

  // Jika user anonym atau belum login owner, tetap tampilkan login page
  if (!user || user.isAnonymous) return renderAuthPage();

  return (
    <div className="min-h-screen bg-[#FDFDFD] flex font-sans">
      <style>{`
        @keyframes loading {
          0% { transform: translateX(-100%); }
          100% { transform: translateX(200%); }
        }
      `}</style>
      
      {/* Sidebar */}
      <aside className={`fixed inset-y-0 left-0 z-50 w-80 bg-slate-900 text-white transform lg:relative lg:translate-x-0 transition-transform duration-500 ${isSidebarOpen ? 'translate-x-0' : '-translate-x-full'} border-r border-slate-800 flex flex-col`}>
        <div className="p-12 flex items-center gap-6 mb-8">
          <MNLogo className="w-14 h-14 shadow-2xl" />
          <div>
            <span className="text-2xl font-black italic tracking-tighter block leading-none">MN STORE</span>
            <p className="text-[10px] font-black text-amber-400 uppercase tracking-widest opacity-60 mt-1.5">Master System</p>
          </div>
        </div>

        <nav className="px-8 space-y-3 flex-1">
          <button onClick={() => setActiveTab('dashboard')} className={`w-full flex items-center gap-5 px-6 py-6 rounded-[32px] transition-all duration-300 ${activeTab === 'dashboard' ? 'bg-amber-400 text-black font-black shadow-2xl shadow-amber-400/20 translate-x-2' : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'}`}>
            <LayoutDashboard className="w-6 h-6" /> <span className="uppercase text-xs font-black italic tracking-tighter">Dashboard</span>
          </button>
          <button onClick={() => setActiveTab('rekap')} className={`w-full flex items-center gap-5 px-6 py-6 rounded-[32px] transition-all duration-300 ${activeTab === 'rekap' ? 'bg-amber-400 text-black font-black shadow-2xl shadow-amber-400/20 translate-x-2' : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'}`}>
            <FileText className="w-6 h-6" /> <span className="uppercase text-xs font-black italic tracking-tighter">Rekap Data</span>
          </button>
          <button onClick={() => setActiveTab('transaksi')} className={`w-full flex items-center gap-5 px-6 py-6 rounded-[32px] transition-all duration-300 ${activeTab === 'transaksi' ? 'bg-amber-400 text-black font-black shadow-2xl shadow-amber-400/20 translate-x-2' : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'}`}>
            <ArrowRightLeft className="w-6 h-6" /> <span className="uppercase text-xs font-black italic tracking-tighter">Transaksi</span>
          </button>
          <button onClick={() => setActiveTab('settings')} className={`w-full flex items-center gap-5 px-6 py-6 rounded-[32px] transition-all duration-300 ${activeTab === 'settings' ? 'bg-amber-400 text-black font-black shadow-2xl shadow-amber-400/20 translate-x-2' : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'}`}>
            <Bot className="w-6 h-6" /> <span className="uppercase text-xs font-black italic tracking-tighter">Bot Config</span>
          </button>
        </nav>

        <div className="p-10 border-t border-white/5">
          <button onClick={handleLogout} className="w-full flex items-center justify-center gap-4 px-6 py-6 rounded-[35px] text-red-500 font-black uppercase italic text-xs border border-red-500/20 hover:bg-red-500/10 transition-all active:scale-95 shadow-lg">
            <LogOut className="w-5 h-5" /> Sign Out
          </button>
        </div>
      </aside>

      {/* Konten Utama */}
      <main className="flex-1 overflow-y-auto">
        <header className="h-28 bg-white border-b border-slate-100 flex items-center justify-between px-16 sticky top-0 z-40 backdrop-blur-md bg-white/90">
          <div className="flex items-center gap-8">
            <button onClick={() => setIsSidebarOpen(!isSidebarOpen)} className="lg:hidden p-4 bg-slate-900 text-white rounded-2xl shadow-xl active:scale-90 transition-transform"><List className="w-6 h-6" /></button>
            <h1 className="text-xs font-black italic uppercase text-slate-400 tracking-[0.5em]">{activeTab} node</h1>
          </div>
          <div className="flex items-center gap-8">
            <div className="text-right hidden sm:block">
              <p className="text-sm font-black italic text-slate-800 uppercase tracking-tighter">Owner MN</p>
              <p className="text-[10px] text-green-500 font-black uppercase tracking-[0.2em] flex items-center justify-end gap-2 mt-1">
                <div className="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></div> Active Secure
              </p>
            </div>
            <div className="w-14 h-14 bg-slate-900 rounded-3xl flex items-center justify-center text-amber-400 font-black italic text-2xl shadow-2xl shadow-slate-200 border-b-4 border-amber-400">M</div>
          </div>
        </header>

        <div className="p-16">
          {activeTab === 'dashboard' && renderDashboard()}
          {activeTab === 'rekap' && renderRekap()}
          {activeTab === 'transaksi' && renderTransaksi()}
          {activeTab === 'settings' && (
            <div className="max-w-xl bg-white p-14 rounded-[55px] border border-slate-100 shadow-2xl shadow-slate-200/50 animate-in zoom-in-95 mx-auto">
              <div className="flex flex-col items-center gap-6 mb-12">
                <div className="p-6 bg-amber-400 rounded-[30px] text-black shadow-xl shadow-amber-200">
                  <Settings className="w-10 h-10" />
                </div>
                <div className="text-center">
                  <h2 className="text-3xl font-black italic text-slate-900 uppercase tracking-tighter">BOT SINKRONISASI</h2>
                  <p className="text-slate-400 text-[10px] font-bold uppercase tracking-widest mt-2">Update API Connection</p>
                </div>
              </div>
              <form className="space-y-8" onSubmit={(e) => {
                e.preventDefault();
                setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'bot_config'), botConfig);
              }}>
                <div className="space-y-2">
                  <label className="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] ml-3">Telegram API Token</label>
                  <input type="password" value={botConfig.token} onChange={(e) => setBotConfig({...botConfig, token: e.target.value})} className="w-full px-8 py-5 bg-slate-50 border border-slate-200 rounded-3xl outline-none focus:ring-8 focus:ring-amber-50 focus:border-amber-400 font-mono text-sm" placeholder="Token API..." />
                </div>
                <div className="space-y-2">
                  <label className="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] ml-3">Bot Username</label>
                  <div className="relative">
                    <span className="absolute left-8 top-1/2 -translate-y-1/2 text-amber-600 font-black text-lg">@</span>
                    <input type="text" value={botConfig.botUsername} onChange={(e) => setBotConfig({...botConfig, botUsername: e.target.value})} className="w-full pl-14 pr-8 py-5 bg-slate-50 border border-slate-200 rounded-3xl outline-none focus:ring-8 focus:ring-amber-50 focus:border-amber-400 font-black text-slate-700" placeholder="mn_store_bot" />
                  </div>
                </div>
                <button type="submit" className="w-full bg-slate-900 text-amber-400 py-6 rounded-[35px] font-black uppercase italic shadow-2xl active:scale-95 transition-all mt-6 text-sm tracking-widest">COMMIT CHANGES</button>
              </form>
            </div>
          )}
        </div>
      </main>
    </div>
  );
}
